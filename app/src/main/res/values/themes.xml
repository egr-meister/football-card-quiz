<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.FootballCardQuiz" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/strong_yellow</item>
        <item name="android:navigationBarColor">@color/strong_yellow</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Custom splash screen: strong yellow background + black quiz-card icon. -->
    <style name="Theme.FootballCardQuiz.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/strong_yellow</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.FootballCardQuiz</item>
    </style>
</resources>
